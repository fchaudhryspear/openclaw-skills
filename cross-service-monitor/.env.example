# Cross-Service Monitor Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# AWS Configuration (Optional)
# ============================================
AWS_REGION=us-east-1

# AWS Credentials are typically loaded from:
# - ~/.aws/credentials (default provider chain)
# - Environment variables AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# - IAM role (when running on EC2/ECS/Lambda)

# ============================================
# Snowflake Configuration (Required for SF monitoring)
# ============================================
SNOWFLAKE_ACCOUNT=your-account-name
SNOWFLAKE_USER=your-username
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=APPLICATIONS
SNOWFLAKE_SCHEMA=PUBLIC

# Authentication: Use EITHER private key OR password
# Private key (recommended for security):
SNOWFLAKE_PRIVATE_KEY="-----BEGIN ENCRYPTED PRIVATE KEY-----\nMIH3..."

# OR Password (less secure, but easier for testing):
# SNOWFLAKE_PASSWORD=your-password-here

# ============================================
# Telegram Alerts (Optional)
# ============================================
# Create a bot via @BotFather on Telegram, get token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat ID for alerts (group/channel/user)
# For groups/channels, include the leading minus sign
# Find your chat ID by messaging @userinfobot
TELEGRAM_CHAT_ID=-1002381931352

# Optional: Telegram dashboard URL (for links in alerts)
TELEGRAM_DASHBOARD_URL=https://monitor.example.com

# ============================================
# Slack Alerts (Optional)
# ============================================
# Create an Incoming Webhook in your Slack workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX

# Optional: URLs for action buttons in Slack messages
SLACK_ACKNOWLEDGE_URL=https://monitor.example.com/alerts
SLACK_DASHBOARD_URL=https://monitor.example.com

# ============================================
# Email Alerts (Optional)
# ============================================
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password  # Not regular password!

# Recipients for critical alerts (comma-separated)
EMAIL_RECIPIENTS=faisal@credologi.com,alerts@company.com

# Dashboard URL for email links
EMAIL_DASHBOARD_URL=https://monitor.example.com

# ============================================
# HubSpot CRM (Optional)
# ============================================
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_PRIVATE_APP_TOKEN=your-private-app-token

# ============================================
# Salesforce CRM (Optional)
# ============================================
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_SESSION_TOKEN=your-session-token

# ============================================
# Dashboard Settings
# ============================================
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# API Key for protecting endpoints (optional)
API_KEY=your-secret-api-key-here

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=/var/log/cross-service-monitor/monitor.log

# ============================================
# Monitoring Intervals (seconds)
# ============================================
HEALTH_CHECK_INTERVAL=60
AWS_CHECK_INTERVAL=60
SNOWFLAKE_CHECK_INTERVAL=300
CRM_CHECK_INTERVAL=300

# ============================================
# Alerting Thresholds
# ============================================
ALERT_LAMBDA_ERROR_RATE=0.05        # 5%
ALERT_SNOWFLAKE_FAILURE_RATE=0.10   # 10%
ALERT_PIPELINE_LAG_MINUTES=15       # 15 minutes
ALERT_DEDUPLICATION_WINDOW=300      # 5 minutes
